DATABASE_URL=postgresql://coco:coco@localhost:5432/coco
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
UPLOAD_DIR=./uploads
WATERMARK_VIDEO_PATH=./assets/coco_watermark.mp4

# OAuth (fill in your own)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Model / generation APIs (fill in when ready)
KLING_API_KEY=
KLING_API_SECRET=
ANTHROPIC_API_KEY=

# Optional monitoring
SENTRY_DSN=

# Runtime switches
ENVIRONMENT=development
MOCK_VIDEO_GENERATION=false
MOCK_IMAGE_GENERATION=false

# Email verification / cloud auth
CLOUD_AUTH_URL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=CoCo <noreply@example.com>

# Local dev login seed
ENABLE_DEV_LOGIN=true
DEV_LOGIN_EMAIL=dev@coco.local
DEV_LOGIN_PASSWORD=change-me

# Polar membership
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_API_BASE=https://api.polar.sh
POLAR_CHECKOUT_URL=
POLAR_DASHBOARD_PRODUCT_URL=
POLAR_MEMBERSHIP_DAYS=30
